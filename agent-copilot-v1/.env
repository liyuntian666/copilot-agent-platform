model_temperature=0.01
model_top_p=0.01
# model_api_key填写你的模型api key
model_api_key=
# model_base_url填写你的模型访问URL地址
model_base_url=
# sim_api_key填写班主任给你的api key
sim_api_key=38068b49d3e249eca5148b1ac50c0815
# 内部安全配置
SECRET_KEY = zhipo_copilot@zhipo.com
JWT_ALGORITHM = 'HS256'
# 本地开发配置
local_mode=1