# 向量数据库的配置
#milvus_uri=http://127.0.0.1:19530
milvus_uri=http://127.0.0.1:19530
milvus_db_name=tool_db
# MongoDB数据库的配置
mongo_host=127.0.0.1
mongo_db=tools
mongo_port=27017
api_result_max_length=30000
api_result_max_threshold=0.1
# 大模型（LLM、向量模型、重排序模型等等）的相关配置
